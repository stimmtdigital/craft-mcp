{
    "name": "stimmt/craft-mcp",
    "description": "MCP (Model Context Protocol) server for Craft CMS",
    "type": "craft-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Max van Essen",
            "email": "support@stimmt.digital",
            "homepage": "https://github.com/vanEssenMax"
        }
    ],
    "homepage": "https://stimmt.digital",
    "support": {
        "email": "support@stimmt.digital",
        "issues": "https://github.com/stimmtdigital/craft-mcp/issues",
        "source": "https://github.com/stimmtdigital/craft-mcp"
    },
    "keywords": [
        "craftcms",
        "craft-plugin",
        "mcp",
        "model-context-protocol",
        "ai",
        "claude",
        "llm",
        "automation"
    ],
    "require": {
        "php": "^8.3",
        "craftcms/cms": "^5.0",
        "mcp/sdk": "^0.7",
        "psr/event-dispatcher": "^1.0",
        "psr/simple-cache": "^2.0 || ^3.0",
        "psy/psysh": "^0.12",
        "symfony/finder": "^6.4 || ^7.3 || ^8.0",
        "symfony/polyfill-php84": "^1.31",
        "nyholm/psr7": "^1.8"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "rector/rector": "2.5.7",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "phpstan/phpstan": "^2.0",
        "sanmai/phpstan-rules": "^0.3.13"
    },
    "autoload": {
        "psr-4": {
            "stimmt\\craft\\Mcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "stimmt\\craft\\Mcp\\Tests\\": "tests/"
        }
    },
    "extra": {
        "handle": "mcp",
        "name": "Craft MCP",
        "developer": "Stimmt Digital",
        "documentationUrl": "https://github.com/stimmtdigital/craft-mcp",
        "class": "stimmt\\craft\\Mcp\\Mcp"
    },
    "bin": [
        "bin/mcp-server"
    ],
    "config": {
        "allow-plugins": {
            "craftcms/plugin-installer": true,
            "yiisoft/yii2-composer": true,
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "policy": {
            "advisories": {
                "block": false
            }
        }
    },
    "scripts": {
        "cut": "php .github/scripts/cut.php",
        "lint": "pint",
        "lint:test": "pint --test",
        "refactor": "rector process",
        "refactor:dry": "rector process --dry-run",
        "fix": [
            "@refactor",
            "@lint"
        ],
        "test": "pest",
        "test:unit": "pest --testsuite=Unit",
        "test:coverage": "pest --coverage --min=80",
        "test:type": "pest --type-coverage --min=90",
        "test:arch": "pest --filter=Arch",
        "analyse": "phpstan analyse --memory-limit=512M",
        "ci": [
            "@lint:test",
            "@refactor:dry",
            "@analyse",
            "@test"
        ],
        "pre-commit": [
            "@fix",
            "@ci"
        ],
        "lefthook:install": "command -v lefthook >/dev/null 2>&1 && lefthook install || true",
        "post-install-cmd": [
            "@lefthook:install"
        ],
        "post-update-cmd": [
            "@lefthook:install"
        ]
    }
}
