{% set userLabels = userLabels ?? [] %}

{% if userLabels is not empty %}
    <p>
        Manage tokens for:
        {% for userId, label in userLabels %}
            <a href="{{ url('users/' ~ userId ~ '/mcp-tokens') }}">{{ label }}</a>{{ not loop.last ? ',' }}
        {% endfor %}
    </p>
{% endif %}

{% include 'mcp/tokens/_table' with {
    tokens: tokens,
    showUser: true,
    userLabels: userLabels,
    revokeAction: revokeAction,
    redirect: redirect,
} only %}
